{% comment %}
Section: Authors Teasers (30-image gallery + optional 18+ blur/gate)
- Age gate resets on reload / close / tab switch (no persistence).
- 6 per-author RICHTEXT titles that render ABOVE chosen portfolio images.
{% endcomment %}

<!-- Include Webflow CSS -->
<link href="{{ section.settings.css_url }}" rel="stylesheet" type="text/css">

<div class="section-authors-teasers" data-section-id="{{ section.id }}">
  <div class="teasers-wrapper">
    <div class="collection-list-2">
      {% for block in section.blocks %}
        <div class="collection-item"{% if block.settings.html_id != blank %} id="{{ block.settings.html_id | escape }}"{% endif %}>
          <div class="author-wrapper" data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd6e" data-block-id="{{ block.id }}">

            <!-- Circle avatar (inline background from OPENED profile image) -->
            <div class="author-profile-image--circle"
                 style="background-image:url({{ block.settings.profile_image | img_url: '900x' }}) !important; background-size:cover!important; background-position:center!important; background-repeat:no-repeat!important;">
            </div>

            {% if block.settings.background_image != blank %}
              <img
                class="background-image-artist"
                src="{{ block.settings.background_image | img_url: '1080x' }}"
                alt="{{ block.settings.author_name | escape }}"
                loading="lazy"
                data-aos="fade"
                data-aos-duration="400"
                data-aos-delay="15">
            {% endif %}

            <!-- Top-right social icon badge (per-author) -->
            {% if block.settings.icon_svg != blank %}
            <div class="div-block-5">
              <div class="social-icon w-embed">
                {% if block.settings.icon_url != blank %}
                  <a href="{{ block.settings.icon_url }}" target="_blank" rel="noopener">
                    {{ block.settings.icon_svg | raw }}
                  </a>
                {% else %}
                  {{ block.settings.icon_svg | raw }}
                {% endif %}
              </div>
            </div>
            {% endif %}

            <!-- Teaser -->
            <div class="author-teaser-content">
              <h1 class="heading">{{ block.settings.author_name }}</h1>
              <div class="divider-65"></div>

              <div class="description-texts">
                <div class="rte description-left">
                  {{ block.settings.author_bio }}
                </div>
                <div class="rte description-right">
                  {{ block.settings.author_price }}
                </div>
              </div>

              <div class="button-wrapper">
                {% if block.settings.book_url != blank %}
                  <a {% if block.settings.book_id != blank %}id="{{ block.settings.book_id | escape }}"{% endif %}
                     href="{{ block.settings.book_url }}" class="btn w-button">
                    {{ block.settings.book_label }}
                  </a>
                {% endif %}
                {% if block.settings.portfolio_url != blank %}
                  <a {% if block.settings.portfolio_id != blank %}id="{{ block.settings.portfolio_id | escape }}"{% endif %}
                     href="{{ block.settings.portfolio_url }}" class="btn w-button">
                    {{ block.settings.portfolio_label }}
                  </a>
                {% endif %}
              </div>
            </div>

            <!-- Circle anim -->
            <div id="circle" data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd75" class="circle-animation" style="width:0vw; height:0vw;"></div>

            <!-- OPENED PANEL -->
            <div class="author-opened-wrapper" style="display:none;">
              <div data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd79" class="author-close-button"></div>

              <div class="button-wrapper-center fixed-middle">
                {% if block.settings.book_url != blank %}
                  <a {% if block.settings.book_id != blank %}id="{{ block.settings.book_id | escape }}"{% endif %}
                     href="{{ block.settings.book_url }}" class="btn w-button">
                    {{ block.settings.book_label }}
                  </a>
                {% endif %}
              </div>

              <!-- LEFT -->
              <div id="w-node-e8a3cb15-7a04-d16d-6771-cfcf8206fd77-178303b5"
                   data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd77"
                   class="author-opened-left" style="opacity:0;">

                <div class="author-opened-left-content-wrapper"
                     style="background-color:#000!important; background-image:var(--mobile-left-gradient, none), var(--mobile-left-image, none) !important; background-size:cover, cover!important; background-position:center, center!important; background-repeat:no-repeat, no-repeat!important;">

                  <div class="author-profile-image"
                       style="background-image:url({{ block.settings.profile_image | img_url: '900x' }}) !important; background-size:cover!important; background-position:center!important; background-repeat:no-repeat!important;">
                  </div>

                  <div data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd87" class="author-social-media-wrapper">
                    {% if block.settings.instagram_url != blank %}
                      <a href="{{ block.settings.instagram_url }}" class="instagram-popup w-inline-block" target="_blank" rel="noopener"></a>
                    {% endif %}
                  </div>

                  <h1 class="heading-2">{{ block.settings.opened_heading }}</h1>
                  <div class="rte text-block">
                    {{ block.settings.opened_text }}
                  </div>

                  {% if block.settings.left_button_show %}
                    <div class="button-wrapper-center">
                      <a {% if block.settings.book_id != blank %}id="{{ block.settings.book_id | escape }}"{% endif %}
                         href="{{ block.settings.book_url }}" class="btn w-button">
                        {{ block.settings.book_label }}
                      </a>
                    </div>
                  {% endif %}
                </div>

                <style>
                  @media (max-width: 991px) {
                    .author-wrapper[data-block-id="{{ block.id }}"] .author-opened-left-content-wrapper {
                      --mobile-left-gradient: linear-gradient(black, rgb(0 0 0 / 36%) 52%, rgb(0, 0, 0));
                      --mobile-left-image: url({{ block.settings.profile_image | img_url: '900x' }});
                    }
                    .author-wrapper[data-block-id="{{ block.id }}"] .author-opened-left-content-wrapper .author-profile-image{
                      display:none;
                    }
                  }
                  @media (min-width: 992px) {
                    .author-wrapper[data-block-id="{{ block.id }}"] .author-opened-left-content-wrapper{
                      --mobile-left-gradient: none;
                      --mobile-left-image: none;
                      background-color:#000 !important;
                    }
                    .author-wrapper[data-block-id="{{ block.id }}"] .author-opened-left-content-wrapper .author-profile-image{
                      display:block;
                    }
                  }
                </style>
              </div>

              <!-- RIGHT -->
              <div data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd7f"
                   class="author-opened-right"
                   style="transform:translate3d(0,0,0) scale3d(1,1,1);transform-style:preserve-3d;">
                <div class="author-opened-content-wrapper">
                  <div class="author-description-wrapper">
                    <h2 data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd82" class="heading-3">
                      {{ block.settings.description_title }}
                    </h2>
                    <div data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd84" class="divider-65 black"></div>

                    <div data-w-id="e8a3cb15-7a04-d16d-6771-cfcf8206fd85" class="rte paragraph-2">
                      {{ block.settings.description_text }}
                    </div>

                    {% if block.settings.description_title_2 != blank %}
                      <h2 class="heading-3" style="margin-top:24px;">
                        {{ block.settings.description_title_2 }}
                      </h2>
                      <div class="divider-65 black"></div>
                    {% endif %}

                    {% if block.settings.description_text_2 != blank %}
                      <div class="rte paragraph-2">
                        {{ block.settings.description_text_2 }}
                      </div>
                    {% endif %}
                  </div>

                  {% assign ai1 = section.settings.adult_image_1_index | default: '#' %}
                  {% assign ai2 = section.settings.adult_image_2_index | default: '#' %}
                  {% assign ai3 = section.settings.adult_image_3_index | default: '#' %}
                  {% assign adult_csv = ',' | append: ai1 | append: ',' | append: ai2 | append: ',' | append: ai3 | append: ',' %}

                  {% assign t1 = block.settings.title_1_index | default: '#' %}
                  {% assign t2 = block.settings.title_2_index | default: '#' %}
                  {% assign t3 = block.settings.title_3_index | default: '#' %}
                  {% assign t4 = block.settings.title_4_index | default: '#' %}
                  {% assign t5 = block.settings.title_5_index | default: '#' %}
                  {% assign t6 = block.settings.title_6_index | default: '#' %}

                  <div class="w-layout-grid grid-2">
                    {% assign gallery = (1..30) %}
                    {% for i in gallery %}
                      {% assign key = 'portfolio_image_' | append: i %}
                      {% if block.settings[key] %}
                        {% assign i_str = i | append: '' %}
                        {% assign token = ',' | append: i_str | append: ',' %}

                        <div class="portfolio-image-item _{{ i }}">
                          {% if t1 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_1_text }}</div>{% endif %}
                          {% if t2 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_2_text }}</div>{% endif %}
                          {% if t3 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_3_text }}</div>{% endif %}
                          {% if t4 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_4_text }}</div>{% endif %}
                          {% if t5 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_5_text }}</div>{% endif %}
                          {% if t6 == i_str %}<div class="portfolio-image-title rte">{{ block.settings.title_6_text }}</div>{% endif %}

                          <div class="portfolio-image{% if adult_csv contains token %} is-adult{% endif %}"
                               role="img"
                               aria-label="{{ block.settings.author_name | escape }} portfolio image {{ i }}"
                               style="background-image:url({{ block.settings[key] | img_url: '900x' }});">
                          </div>

                          {% if adult_csv contains token %}
                            <button type="button"
                                    class="age-gate-overlay"
                                    data-section="{{ section.id }}"
                                    data-block="{{ block.id }}"
                                    data-idx="{{ i }}"
                                    aria-label="This image is 18+, tap to verify age">
                              <span class="age-badge">{{ section.settings.adult_badge_text }}</span>
                              <span class="age-instruction">{{ section.settings.adult_badge_subtext }}</span>
                            </button>
                          {% endif %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div><!-- /.author-opened-wrapper -->

          </div><!-- /.author-wrapper -->
        </div><!-- /.collection-item -->
      {% endfor %}
    </div>
  </div>

  <!-- AGE-GATE MODAL (once per section) -->
  <div class="age-modal" id="age-modal-{{ section.id }}" hidden>
    <div class="age-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="age-modal-title-{{ section.id }}">
      <h3 id="age-modal-title-{{ section.id }}">{{ section.settings.adult_modal_title }}</h3>
      <p class="age-modal__desc">{{ section.settings.adult_modal_text }}</p>

      <label class="age-modal__label">
        <span>{{ section.settings.adult_modal_label }}</span>
        <input type="date"
               id="age-date-{{ section.id }}"
               class="age-modal__date"
               max="{{ 'now' | date: '%Y-%m-%d' }}">
      </label>

      <p class="age-modal__error" id="age-error-{{ section.id }}" hidden>{{ section.settings.adult_error_text }}</p>

      <div class="age-modal__actions">
        <button type="button" class="btn age-cancel">{{ section.settings.adult_cancel_text }}</button>
        <button type="button" class="btn age-submit">{{ section.settings.adult_submit_text }}</button>
      </div>
    </div>
  </div>
</div>

<script>
/* Age-gate logic (scoped to this section) — NO persistence (always ask again) */
(function() {
  var root = document.querySelector('.section-authors-teasers[data-section-id="{{ section.id }}"]');
  if (!root) return;

  var isEditor = document.documentElement.classList.contains('shopify-design-mode');
  var modal = document.getElementById('age-modal-{{ section.id }}');
  var input = document.getElementById('age-date-{{ section.id }}');
  var err = document.getElementById('age-error-{{ section.id }}');
  var minAge = {{ section.settings.adult_min_age | json }};
  var UNDERAGE_MSG = {{ section.settings.adult_error_text | json }};
  var INVALID_MSG = "Please enter a valid birthdate.";
  var verified = false;

  // set input[min] = today - 130 years (prevents >130yo)
  if (input) {
    var today = new Date();
    var oldest = new Date(today.getFullYear() - 130, today.getMonth(), today.getDate());
    input.setAttribute('min', oldest.toISOString().slice(0,10));
  }

  function markVerified() { verified = true; root.classList.add('adult-verified'); }
  function markUnverified() { verified = false; root.classList.remove('adult-verified'); if (input) input.value = ''; if (err) err.hidden = true; }

  // Always start unverified (unless explicitly bypassed in editor)
  markUnverified();
  if (isEditor && {{ section.settings.adult_disable_in_editor | json }}) {
    markVerified();
  }

  function openModal() {
    if (!modal) return;
    modal.hidden = false;
    requestAnimationFrame(function(){ modal.classList.add('open'); });
    if (input) input.focus({ preventScroll: true });
  }
  function closeModal() {
    if (!modal) return;
    modal.classList.remove('open');
    setTimeout(function(){ modal.hidden = true; }, 150);
    if (err) err.hidden = true;
  }
  function showError(msg) {
    if (!err) return;
    err.textContent = msg;
    err.hidden = false;
  }
  function clearError() { if (err) err.hidden = true; }

  // Click: any 18+ image overlay
  root.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.age-gate-overlay');
    if (!btn) return;
    if (verified) return;
    ev.preventDefault();
    openModal();
  });

  // Reset verification when portfolio panel closes
  root.addEventListener('click', function(ev) {
    var closeBtn = ev.target.closest('.author-close-button');
    if (!closeBtn) return;
    markUnverified();
  });

  // Extra safety: if the tab/app is backgrounded or page is being hidden, reset
  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'hidden') markUnverified();
  });

  if (modal) {
    var cancelBtn = modal.querySelector('.age-cancel');
    var submitBtn = modal.querySelector('.age-submit');
    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
    if (input) input.addEventListener('input', clearError);

    function getAgeFromDateString(s) {
      var d = new Date(s);
      if (isNaN(d.getTime())) return NaN;
      var t = new Date();
      var age = t.getFullYear() - d.getFullYear();
      var m = t.getMonth() - d.getMonth();
      if (m < 0 || (m === 0 && t.getDate() < d.getDate())) age--;
      return age;
    }

    function handleSubmit() {
      var val = (input && input.value || '').trim();
      if (!val) { showError(INVALID_MSG); return; }

      var age = getAgeFromDateString(val);

      // sanity checks: invalid date, ≤0 years old, or >130 years old
      if (isNaN(age) || age <= 0 || age > 130) {
        showError(INVALID_MSG);
        return;
      }

      if (age >= minAge) {
        markVerified();
        closeModal();
      } else {
        showError(UNDERAGE_MSG);
      }
    }

    if (submitBtn) submitBtn.addEventListener('click', handleSubmit);
    if (input) input.addEventListener('keydown', function(e){
      if (e.key === 'Enter') { e.preventDefault(); handleSubmit(); }
      if (e.key === 'Escape') { e.preventDefault(); closeModal(); }
    });
  }
})();
</script>

