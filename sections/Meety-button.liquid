        { "type": "product", "id": "bogo_tracking_product_tattoo", "label": "Tracking Product – Tattoo" },
        {
          "type": "textarea",
          "id": "tattoo_calendar_json",
          "label": "Tattoo BOGO Calendar JSON",
          "info": "OVERRIDE: Use this specific calendar for Tattoo BOGO. If blank, the Primary Calendar is used.",
          "default": "#"
        },
        
        { "type": "header", "content": "📅 No-Calendar Mode (Instagram Scheduling)" },
        {
          "type": "paragraph",
          "content": "For artists without set schedules (e.g., Ashley), enable Instagram scheduling mode. Customers will be directed to Instagram to check availability instead of seeing a calendar."
        },
        { "type": "checkbox", "id": "no_calendar_mode", "label": "Enable No-Calendar Mode (Instagram Scheduling)", "default": false, "info": "Skip calendar step, show Instagram redirect option" },
        { "type": "text", "id": "instagram_url", "label": "Instagram Profile URL", "info": "Artist's Instagram URL for scheduling (e.g., https://instagram.com/ashley_tattoo)", "default": "#" },
        
        { "type": "header", "content": "🛒 Instagram Mode - Product Configuration" },
        {
          "type": "paragraph",
          "content": "Configure which products get added to cart for different flows when using Instagram scheduling mode. These are ONLY used when No-Calendar Mode is enabled."
        },
        { "type": "product", "id": "instagram_booking_product", "label": "Product for 'Book for Myself' Flow", "info": "Product added when customer books a service for themselves in Instagram mode" },
        { "type": "product", "id": "instagram_redeem_product", "label": "Product for 'Redeem Gift Card' Flow", "info": "Product added when customer redeems a gift card in Instagram mode" },
        
        { "type": "header", "content": "🎁 Gift Card & Promotion Setup" },
        {
          "type": "paragraph",
          "content": "These settings configure the 'Promo' option in the 'Multi-Step Promotional Chooser' flow."
        },
  { "type": "checkbox", "id": "enable_promo", "label": "Enable Black Friday / Promo Option (3rd path)", "default": true },
  { "type": "text", "id": "promo_title", "label": "Promo Button Title", "default": "Black Friday Deals" },
