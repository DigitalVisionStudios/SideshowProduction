{% comment %}
Sticky CTA Button — multi-position + auto-hide on popup + center vertical adjust
Adds:
• Hide at top until scrolling (uses body.is-scrolling with JS fallback)
• Auto-hide when your .image-popup gets .visible
{% endcomment %}

<section id="sticky-cta-{{ section.id }}" class="sticky-cta-wrapper" data-section-id="{{ section.id }}">
  {% liquid
    assign vp = section.settings.vertical_position
    assign btn_text = section.settings.button_text
    assign text_color = section.settings.text_color
    assign bg_color = section.settings.bg_color
    assign border_color = section.settings.border_color
    assign border_width = section.settings.border_width
    assign hover_bg = section.settings.hover_bg_color
    assign hover_text = section.settings.hover_text_color
    assign size = section.settings.button_size
    assign offset_x = section.settings.offset_x
    assign offset_y = section.settings.offset_y
    assign center_adjust = section.settings.center_y_adjust
    assign radius = section.settings.border_radius
    assign z = section.settings.z_index
    assign custom_class = section.settings.custom_class
    assign href_final = section.settings.link_url_pick | default: section.settings.link_url
  %}

  <style>
    #sticky-cta-{{ section.id }} .sticky-cta-btn {
      position: fixed;
      z-index: {{ z }};
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-weight: 600;
      line-height: 1;
      border-radius: {{ radius }}px;
      border: {{ border_width }}px solid {{ border_color }};
      background: {{ bg_color }};
      color: {{ text_color }};
      box-shadow: 0 8px 18px rgba(0,0,0,.12);
      transition: opacity .25s ease, box-shadow .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
      -webkit-tap-highlight-color: transparent;
      transform-origin: center center;
      opacity: 1; /* default visible */
    }

    #sticky-cta-{{ section.id }} .sticky-cta-btn:hover {
      background: {{ hover_bg }};
      color: {{ hover_text }};
      box-shadow: 0 10px 22px rgba(0,0,0,.16);
    }

    /* Size variants */
    #sticky-cta-{{ section.id }} .size-sm { font-size: 14px; padding: 10px 14px; min-height: 44px; }
    #sticky-cta-{{ section.id }} .size-md { font-size: 15px; padding: 12px 16px; min-height: 46px; }
    #sticky-cta-{{ section.id }} .size-lg { font-size: 16px; padding: 14px 20px; min-height: 48px; }

    /* ===== Position variants ===== */

    /* Bottom-right */
    #sticky-cta-{{ section.id }} .pos-bottom-right {
      right: {{ offset_x }}px;
      bottom: {{ offset_y }}px;
    }

    /* Middle-right (side, horizontal) */
    #sticky-cta-{{ section.id }} .pos-middle-right {
      right: {{ offset_x }}px;
      top: calc(50% + {{ center_adjust }}px);
      transform: translateY(-50%);
    }

    /* Right (rotated 90°) — vertical tab */
    #sticky-cta-{{ section.id }} .pos-right-rotated {
      right: {{ offset_x }}px;
      top: calc(50% + {{ center_adjust }}px);
      transform: translateY(-50%) rotate(-90deg);
    }

    /* Bottom-center */
    #sticky-cta-{{ section.id }} .pos-bottom-center {
      left: 50%;
      bottom: {{ offset_y }}px;
      transform: translateX(-50%);
    }

    /* Middle-left (side, horizontal) */
    #sticky-cta-{{ section.id }} .pos-middle-left {
      left: {{ offset_x }}px;
      top: calc(50% + {{ center_adjust }}px);
      transform: translateY(-50%);
    }

    /* Left rotated (vertical tab) */
    #sticky-cta-{{ section.id }} .pos-left-rotated {
      left: {{ offset_x }}px;
      top: calc(50% + {{ center_adjust }}px);
      transform: translateY(-50%) rotate(90deg);
    }

    /* Hide on device toggles */
    {% if section.settings.hide_on_desktop %}
      @media (min-width: 750px) { #sticky-cta-{{ section.id }} .sticky-cta-btn { display: none !important; } }
    {% endif %}
    {% if section.settings.hide_on_mobile %}
      @media (max-width: 749px) { #sticky-cta-{{ section.id }} .sticky-cta-btn { display: none !important; } }
    {% endif %}

    /* Auto-hide when popup is open (MutationObserver below toggles html.popup-open) */
    {% if section.settings.auto_hide_on_popup %}
      html.popup-open #sticky-cta-{{ section.id }} .sticky-cta-btn { display: none !important; }
    {% endif %}

    /* Hide at very top; fade in when body.has(.is-scrolling) */
    {% if section.settings.show_only_when_scrolling %}
      body:not(.is-scrolling) #sticky-cta-{{ section.id }} .sticky-cta-btn {
        opacity: 0;
        pointer-events: none;
      }
    {% endif %}
  </style>

  {% if href_final != blank %}
    <a
      class="sticky-cta-btn {{ custom_class | escape }} size-{{ size }} pos-{{ vp }}"
      href="{{ href_final }}"
      {% if section.settings.open_in_new_tab %}target="_blank"{% endif %}
      {% if section.settings.no_follow or section.settings.open_in_new_tab %}rel="{% if section.settings.no_follow %}nofollow {% endif %}noopener noreferrer"{% endif %}
      aria-label="{{ btn_text | escape }}"
      data-sticky-cta
    >
      {{ btn_text }}
    </a>
  {% endif %}
</section>

{% schema %}
