{% javascript %}
(function() {
  var root = document.documentElement;
  var body = document.body;

  /* === A) Toggle html.popup-open when any .image-popup.visible exists === */
  function syncPopupOpenFlag() {
    var anyOpen = !!document.querySelector('.image-popup.visible');
    if (anyOpen) { root.classList.add('popup-open'); }
    else { root.classList.remove('popup-open'); }
  }
  syncPopupOpenFlag();

  try {
    var mo = new MutationObserver(function() {
      if (!syncPopupOpenFlag._scheduled) {
        syncPopupOpenFlag._scheduled = true;
        requestAnimationFrame(function() {
          syncPopupOpenFlag();
          syncPopupOpenFlag._scheduled = false;
        });
      }
    });
    mo.observe(document.body, { attributes: true, childList: true, subtree: true, attributeFilter: ['class'] });
  } catch (e) {
    setInterval(syncPopupOpenFlag, 500);
  }

  /* === B) Ensure body.has('is-scrolling') when scrolled past top (fallback) ===
     Many themes add this already; this just guarantees the class exists when scrollY > 0. */
  var SHOW_ON_SCROLL = {{ section.settings.show_only_when_scrolling | json }};

  function applyIsScrolling() {
    if (!SHOW_ON_SCROLL) return;
    var scrolled = window.scrollY > 0;
    if (scrolled) body.classList.add('is-scrolling');
    else body.classList.remove('is-scrolling');
  }

  // rAF-throttled scroll handler
  var ticking = false;
  function onScroll() {
    if (!SHOW_ON_SCROLL) return;
    if (!ticking) {
      requestAnimationFrame(function() {
        applyIsScrolling();
        ticking = false;
      });
      ticking = true;
    }
  }

  // Initial + listeners
  applyIsScrolling();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('pageshow', applyIsScrolling);
  window.addEventListener('resize', applyIsScrolling);
})();
{% endjavascript %}
