    "custom_html_CC7nmV": {
      "type": "custom-html",
      "blocks": {
        "html_tNLip8": {
          "type": "html",
          "disabled": true,
          "settings": {
            "title": "demo script",
            "code": "<script> \ndocument.addEventListener('DOMContentLoaded', function() {\n    // Function to modify links\n    function modifyLinks() {\n        var links = document.getElementsByTagName('a');\n        for (var i = 0; i < links.length; i++) {\n            links[i].href = '#'; // Change the href attribute to '#'\n            links[i].addEventListener('click', function(event) {\n                event.preventDefault(); // Prevent the default action\n            });\n        }\n    }\n\n    // Call the function initially to modify existing links\n    modifyLinks();\n\n    // Mutation Observer to observe changes in the DOM\n    var observer = new MutationObserver(function(mutations) {\n        mutations.forEach(function(mutation) {\n            if (mutation.addedNodes.length > 0) {\n                modifyLinks(); // Call modifyLinks for new elements added to the DOM\n            }\n        });\n    });\n\n    // Configuration of the observer\n    var config = { childList: true, subtree: true };\n\n    // Start observing the body for changes in the DOM\n    observer.observe(document.body, config);\n});\n\n</script>",
            "column_width": 1,
            "column_width_mobile": 1,
            "text_alignment": "text-center"
          }
        },
        "html_ET7Mrt": {
          "type": "html",
          "settings": {
            "title": "Scrolls code",
            "code": "<script>\n(function () {\n  \"use strict\";\n\n  // ---- helpers ----\n  // Polyfill CSS.escape if missing\n  if (typeof window.CSS === \"undefined\" || typeof CSS.escape !== \"function\") {\n    // Minimal escape that covers quotes and specials used in attribute selectors\n    window.CSS = window.CSS || {};\n    CSS.escape = function (val) {\n      return String(val).replace(/[\"\\\\]/g, \"\\\\$&\");\n    };\n  }\n\n  const MARKER_RE = /\\(\\(scroll=([^\\),]+)(?:,offset=(-?\\d+))?\\)\\)/; // ((scroll=target,offset=-100))\n  const HASH_RE = /^\\#\\(\\(scroll=/;\n\n  function parseMarker(str) {\n    if (!str) return null;\n    const m = str.match(MARKER_RE);\n    if (!m) return null;\n    return { target: m[1], offset: m[2] ? parseInt(m[2], 10) : 0 };\n  }\n\n  // Convert inline marker text → data attributes on parent element, remove marker text\n  function addCustomAttributes(root = document.body) {\n    try {\n      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);\n      let node;\n      while ((node = walker.nextNode())) {\n        if (!node.nodeValue || !node.parentElement) continue;\n        let text = node.nodeValue;\n        let anyChange = false;\n        let m;\n        while ((m = text.match(MARKER_RE))) {\n          const target = m[1];\n          const offset = m[2];\n          node.parentElement.setAttribute(\"data-scroll-target\", target);\n          if (offset) node.parentElement.setAttribute(\"data-scroll-offset\", offset);\n          text = text.replace(MARKER_RE, \"\");\n          anyChange = true;\n        }\n        if (anyChange) node.nodeValue = text;\n      }\n    } catch (err) {\n      console.debug(\"[scroll-markers] addCustomAttributes error:\", err);\n    }\n  }\n\n  function computeYOffset(el, explicitOffset) {\n    if (explicitOffset != null) return explicitOffset;\n    const attr = el.getAttribute(\"data-scroll-offset\");\n    return attr ? (parseInt(attr, 10) || 0) : 0;\n  }\n\n  function scrollToTarget(value, explicitOffset) {\n    const el = document.querySelector('[data-scroll-target=\"' + CSS.escape(value) + '\"]');\n    if (!el) return false;\n    const yOffset = computeYOffset(el, explicitOffset);\n    const top = el.getBoundingClientRect().top + window.pageYOffset + yOffset;\n    window.scrollTo({ top, behavior: \"smooth\" });\n    return true;\n  }\n\n  // Retry for a short window in case DOM arrives late\n  function tryScrollUntilFound(value, explicitOffset, timeoutMs = 2000) {\n    const start = performance.now();\n    (function tick() {\n      if (scrollToTarget(value, explicitOffset)) return;\n      if (performance.now() - start > timeoutMs) return;\n      requestAnimationFrame(tick);\n    })();\n  }\n\n  // EVENT DELEGATION: handle clicks on links that have our scroll marker in the hash\n  function onDocumentClick(e) {\n    // Use closest('a') to capture clicks on descendants inside links\n    const a = e.target.closest && e.target.closest('a[href*=\"#((scroll=\"]');\n    if (!a) return;\n\n    const href = a.getAttribute(\"href\") || \"\";\n    const hashPart = href.split(\"#\").slice(1).join(\"#\"); // supports URLs that already have ?query\n    const decoded = decodeURIComponent(\"#\" + hashPart);\n    if (!HASH_RE.test(decoded)) return;\n\n    const marker = parseMarker(decoded);\n    if (!marker) return;\n\n    e.preventDefault(); // stop native jump\n    tryScrollUntilFound(marker.target, marker.offset);\n  }\n\n  // Read marker from hash or query (?s= / ?scroll=)\n  function getMarkerFromUrl() {\n    if (HASH_RE.test(window.location.hash)) {\n      const decoded = decodeURIComponent(window.location.hash);\n      const m = parseMarker(decoded);\n      if (m) return m;\n    }\n    const params = new URLSearchParams(window.location.search);\n    const raw = params.get(\"s\") || params.get(\"scroll\");\n    if (raw) {\n      const decoded = decodeURIComponent(raw);\n      const m = parseMarker(decoded);\n      if (m) return m;\n    }\n    return null;\n  }\n\n  // MutationObserver to process newly injected DOM\n  const mo = new MutationObserver((mutations) => {\n    for (const m of mutations) {\n      for (const n of m.addedNodes) {\n        if (n && n.nodeType === 1) {\n          addCustomAttributes(n);\n        }\n      }\n    }\n  });\n\n  // ---- boot ----\n  // Use DOMContentLoaded in case this script is not deferred\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    addCustomAttributes(); // convert markers in existing DOM\n\n    // Delegate clicks at the document level → avoids null .addEventListener on missing nodes\n    document.addEventListener(\"click\", onDocumentClick, { passive: false });\n\n    // Auto-scroll from URL markers\n    const marker = getMarkerFromUrl();\n    if (marker) {\n      // small delay to let layout stabilize (theme scripts, fonts, etc.)\n      setTimeout(() => tryScrollUntilFound(marker.target, marker.offset), 150);\n    }\n\n    // Observe dynamic injections\n    mo.observe(document.body, { childList: true, subtree: true });\n  });\n})();\n</script>",
