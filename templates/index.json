            "code": "<style>\n.image-popup .image-container {\n    background-color: black;\n    padding: 10px;\n    text-align: center; /* Center the content */\n}\n.image-popup .btn-outline-primary:hover {\n    color: black; /* Black font color on hover */\n    background-color: white; /* Optional: change background color on hover */\n}\n\n.image-popup .btn-outline-primary {\n    display: inline-block; /* Adjust display */\n    margin-top: 20px; /* Add space above the button */\n    margin-bottom: 20px; /* Add space below the button for separation from the image */\n    padding: 10px 20px;\n    border: 2px solid white; /* White border */\n    color: white; /* White text */\n    background-color: transparent;\n    cursor: pointer;\n    text-align: center;\n    text-decoration: none; /* Remove underline */\n    font-size: 1em; /* Adjust font size as needed */\n    border-radius: 5px; /* Optional: rounded corners */\n}\n\n.backdrop {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-color: rgba(0, 0, 0, 0.5); /* 50% black */\n    display: none;\n    z-index: 999; /* Below the popup */\n}\n\n.no-scroll {\n    overflow: hidden;\n    position: fixed;\n    width: 100%;\n}\n\n/* Common Styles for All Screens */\n.image-popup {\n    position: fixed;\n    background-color: black;\n    box-shadow: 0 5px 15px rgba(0,0,0,0.3);\n    transition: transform 0.5s ease, opacity 0.5s ease;\n    z-index: 1000;\n    opacity: 0;\n    padding: 26px;\n}\n\n.image-popup img {\n    width: 100%;\n    height: auto;\n    display: block;\n    margin-bottom: 20px; /* Ensure space between the image and button if button class is mismatched */\n}\n\n.close-btn {\n    position: absolute;\n    top: 10px;\n    right: 20px;\n    font-size: 30px;\n    cursor: pointer;\n}\n\n/* Tablet and Desktop Styles */\n@media (min-width: 601px) {\n    .image-popup {\n        left: 50%;\n        top: 50%;\n        transform: translate(-50%, -50%) scale(0);\n        max-width: 35vw; /* Maximum width */\n    min-width: 288px;\n    }\n\n    .image-popup.visible {\n        transform: translate(-50%, -50%) scale(1);\n        opacity: 1; /* Fade in */\n    }\n}\n\n/* Mobile Styles */\n@media (max-width: 600px) {\n    .image-popup {\n        width: 100%;\n        bottom: -100%; /* Start from below the screen */\n        left: 0;\n        transform: translate(0, 0);\n    }\n\n    .image-popup.visible {\n        bottom: 0; /* Slide up */\n        opacity: 1; /* Show element */\n    }\n}\n\n</style>",
