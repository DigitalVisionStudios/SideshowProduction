        "html_hwz7CP": {
          "type": "html",
          "settings": {
            "title": "",
            "code": "<script>\n  // Function to execute when the target container is available\n  function modifyContent() {\n    var container = document.querySelector('#shopify-section-template--22020303290668__map_HDLKGK .rte');\n    if (!container) return;\n\n    var daysAndHours = container.querySelectorAll('h5');\n    var gridContainer = document.createElement('div');\n    gridContainer.style.display = 'grid';\n    gridContainer.style.gridTemplateColumns = '1fr 1fr';\n    gridContainer.style.gap = '10px';\n\n    var asteriskContent = '';\n\n    daysAndHours.forEach(function(dayHour) {\n      var dayText = dayHour.childNodes[0].textContent.trim();\n      var hourText = dayHour.querySelector('em').textContent.trim();\n\n      var dayDiv = document.createElement('div');\n      dayDiv.textContent = dayText;\n      var hourDiv = document.createElement('div');\n      hourDiv.innerHTML = '<em>' + hourText + '</em>';\n\n      gridContainer.appendChild(dayDiv);\n      gridContainer.appendChild(hourDiv);\n    });\n\n    // Extract and style content from p elements\n    var pElements = container.querySelectorAll('p');\n    pElements.forEach(function(p) {\n      asteriskContent += p.innerHTML.replace(/\\*\\*(.*?)\\*\\*/g, '<small style=\"font-size: smaller;\">$1</small>');\n    });\n\n    // Append asterisk content at the end, if any\n    if (asteriskContent) {\n      var asteriskDiv = document.createElement('div');\n      asteriskDiv.innerHTML = asteriskContent;\n      asteriskDiv.style.gridColumn = '1 / span 2'; // Span both columns\n      gridContainer.appendChild(asteriskDiv);\n    }\n\n    container.innerHTML = '';\n    container.appendChild(gridContainer);\n  }\n\n  // Create a MutationObserver to observe DOM changes\n  var observer = new MutationObserver(function(mutations, obs) {\n    if (document.querySelector('#shopify-section-template--22020303290668__map_HDLKGK .rte')) {\n      modifyContent();\n      obs.disconnect(); // Disconnect observer after successful modification\n    }\n  });\n\n  // Start observing the document body\n  observer.observe(document.body, {\n    childList: true,\n    subtree: true\n  });\n</script>",
