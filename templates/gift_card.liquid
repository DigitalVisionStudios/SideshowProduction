{%- layout 'gift_card' -%}

{%- assign formatted_initial_value = gift_card.initial_value | money_without_trailing_zeros: gift_card.currency -%}
{%- assign formatted_initial_value_stripped = formatted_initial_value | strip_html -%}

<header class="giftcard-header" role="banner">
  <div class="h1 header-logo" itemscope itemtype="http://schema.org/Organization">
    <a href="/" itemprop="url">{{ shop.name }}</a>
  </div>
  <div class="shop-url">{{ shop.url }}</div>
</header>

    <main class="giftcard" role="main">
      <div class="giftcard__border{% if gift_card.expired or gift_card.enabled != true %} disabled{% endif %}">
        <div class="giftcard__content">

          <div class="giftcard__header">
            <h2 class="h4 giftcard__title">{{ 'gift_cards.issued.subtext' | t }}</h2>
            {%- unless gift_card.enabled -%}
              <span class="giftcard__tag">{{ 'gift_cards.issued.disabled' | t }}</span>
            {%- endunless -%}

            {%- assign gift_card_expiry_date = gift_card.expires_on | date: "%d/%m/%y" -%}

            {%- if gift_card.expired and gift_card.enabled -%}
               <span class="giftcard__tag">{{ 'gift_cards.issued.expired' | t: expiry: gift_card_expiry_date }}</span>
            {%- endif -%}

            {%- if gift_card.expired != true and gift_card.expires_on and gift_card.enabled -%}
              <span class="giftcard__tag giftcard__tag--active">{{ 'gift_cards.issued.active' | t: expiry: gift_card_expiry_date }}</span>
            {%- endif -%}
          </div>

          <div class="giftcard__wrap">
            <img src="{{ 'gift-card/card.jpg' | shopify_asset_url }}" alt="Gift card illustration">

            {%- assign initial_value_size = formatted_initial_value | size -%}
            <div class="h1 giftcard__amount{%- if initial_value_size > 6 -%} giftcard__amount--medium{%- endif -%}">
              {%- if gift_card.balance != gift_card.initial_value -%}
                <span class="tooltip">
                  <span class="tooltip__label"><span class="money">{{ gift_card.balance | money }}</span> <small>left</small></span>
                </span>
              {%- endif -%}

              <strong>{{ formatted_initial_value }}</strong>
            </div>

            {%- assign code_size = gift_card.code | format_code | size -%}

            <div class="giftcard__code{% if code_size <= 25 %} giftcard__code--large{% elsif code_size > 25 and code_size <= 30 %} giftcard__code--medium{% else %} giftcard__code--small{% endif %}" onclick="selectText('GiftCardDigits');">
              <div class="giftcard__code__inner">
                <strong class="giftcard__code__text" id="GiftCardDigits">{{ gift_card.code | format_code }}</strong>
              </div>
            </div>
          </div>

          <p class="giftcard__instructions">
            {{ 'gift_cards.issued.redeem' | t }}
          </p>

          <div id="QrCode"></div>
          <script>
            new QRCode(document.getElementById('QrCode'), {
              text: "{{ gift_card.qr_identifier }}",
              width: 120,
              height: 120
            });
          </script>

          <div class="giftcard__actions">
            <a href="{{ shop.url }}" class="btn btn--primary" target="_blank">{{ 'gift_cards.issued.shop_link' | t }}</a>
            <a href="#" class="action-link" onclick="window.print();">
              <span class="{{ settings.icon }}">print</span> {{ 'gift_cards.issued.print' | t }}
            </a>
          </div>

        </div>
      </div>
    </main>

    

<footer class="giftcard__footer" role="contentinfo">
  {%- if gift_card.pass_url -%}
    <a class="add-to-apple-wallet" href="{{ gift_card.pass_url }}">
      <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" width="120" height="40" alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}">
    </a>
  {%- endif -%}
</footer>
<!-- Minimal fixes + color theming -->
<style>
  /* theme palette */
  :root{
    --gc-bg: #0e0f12;
    --gc-card: #15161b;
    --gc-text: #f6f7fb;
    --gc-muted: #9aa0aa;
    --gc-border: #2a2d36;
    --gc-accent: #ef4444;   /* red */
    --gc-accent-2: #f97316; /* red-orange */
    --gc-chip: #0f1217;
  }

  /* gradient on BODY + wrapper (color only) */
  body,
  .wrapper{
    background:
      radial-gradient(1000px 480px at 8% -10%, color-mix(in oklab, var(--gc-accent) 16%, transparent) 0%, transparent 60%),
      radial-gradient(900px 420px at 110% 110%, color-mix(in oklab, var(--gc-accent-2) 14%, transparent) 0%, transparent 60%),
      var(--gc-bg) !important;
  }

  /* card surface + text color only */
  .giftcard__content{ background: var(--gc-card); color: var(--gc-text); }
  .giftcard__instructions{ color: var(--gc-muted); }

  /* make outer frame black */
  .giftcard__border{
    background: #000 !important;
    border: 1px solid #000 !important;
  }

  /* code chip should not float over amount (no layout change elsewhere) */
  .giftcard__code{
    position: static !important;
    margin-top: 0 !important;             /* neutralize theme's negative margin */
    z-index: 1;
  }
  .giftcard__code__inner{
    background: var(--gc-chip);
    border: 1px solid var(--gc-border);
    color: var(--gc-text);
  }
  .giftcard__code__text{ color: var(--gc-text); }

  /* keep amount readable (color only; no size edit) */
  .giftcard__amountgiftcard__amount--medium strong{
    background: linear-gradient(90deg, var(--gc-accent), var(--gc-accent-2));
    -webkit-background-clip: text;
            background-clip: text;
    color: transparent;
  }

  /* CTA colors only */
  .giftcard__actions .btn--primary{
    background: linear-gradient(90deg, var(--gc-accent), var(--gc-accent-2));
    color: #0b0c10 !important;
    border-color: var(--gc-border);
  }
  .giftcard__actions .action-link{
    background: var(--gc-chip);
    border-color: var(--gc-border);
    color: var(--gc-text);
  }

  /* image border color only */
  .giftcard__wrap img[alt*="Gift card illustration"]{ border-color: var(--gc-border); }
</style>

<script>
  // swap header text link for your logo (keeps the same <a href="/">)
  (function(){
    const link = document.querySelector('.giftcard-header .header-logo a[itemprop="url"]');
    if (!link) return;

    const logoHTML = `
      <img class="default-logo imgset radius-none"
           width="60"
           src="//sideshowproductionstattoo.com/cdn/shop/files/223478660_567934514208240_296589035920691442_n_430x_5421b8ca-d292-4f2b-8bb0-1aa6ffb91edc_60x.png?v=1707277795"
           srcset="//sideshowproductionstattoo.com/cdn/shop/files/223478660_567934514208240_296589035920691442_n_430x_5421b8ca-d292-4f2b-8bb0-1aa6ffb91edc_60x.png?v=1707277795 1x, //sideshowproductionstattoo.com/cdn/shop/files/223478660_567934514208240_296589035920691442_n_430x_5421b8ca-d292-4f2b-8bb0-1aa6ffb91edc_60x@2x.png?v=1707277795 2x"
           alt="Sideshow Productions" itemprop="logo">`;

    link.setAttribute('aria-label', 'Sideshow Productions');
    link.innerHTML = logoHTML;
  })();
</script>
